    print("\n" + "-" * 30)
    print("MULTIPLICAÇÃO DE MATRIZES")
    size = 50
    A = np.random.rand(size, size).tolist()
    B = np.random.rand(size, size).tolist()
    start = time.time()
    multiply_matrices(A, B)
    print(f"Tempo para matriz {size}x{size}: {time.time() - start:.4f}s")
    
    print("\n" + "-" * 30)
    print("SIMULAÇÃO DE RECORRÊNCIAS")

    res_a = solve_recurrence(1024, 2, 4, lambda n: math.sqrt(n))

    res_b = solve_recurrence(1024, 2, 4, lambda n: n)

    res_c = solve_recurrence(1024, 16, 4, lambda n: n**2)
    
    print(f"Recorrência A (O(√n log n)): {res_a:.2f}")
    print(f"Recorrência B (O(n)):         {res_b}")
    print(f"Recorrência C (O(n² log n)):  {res_c}")
    print("-" * 30)
